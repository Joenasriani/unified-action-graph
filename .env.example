# Unified Action Graph environment example
# Copy to .env.local for local development.

# OpenRouter free auto-router configuration.
# Keep API keys server-side only. Do not inject them into the Vite client bundle.
UNIFIED_ACTION_GRAPH_API=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
AI_MODEL=openrouter/free

# Optional compatibility aliases. Leave empty unless a future backend service expects them.
OPENROUTER_API_KEY=
ROBOMARKET_API=
FREE_ROBOMARKET_API=

# Optional request metadata for OpenRouter when implemented through a server route.
OPENROUTER_HTTP_REFERER=https://github.com/Joenasriani/unified-action-graph
OPENROUTER_APP_TITLE=Unified Action Graph

# Optional public GitHub REST API token for higher rate limits.
# Do not prefix with VITE_. This must stay server-side.
GITHUB_PUBLIC_TOKEN=

# Optional app URL for deployed environments.
APP_URL=
